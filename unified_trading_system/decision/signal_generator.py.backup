"""
Signal Generation for Trading System
Converts belief states into actionable trading signals
"""
import numpy as np
from typing import List, Dict, Optional
from dataclasses import dataclass
from perception.belief_state import BeliefState, RegimeType


@dataclass
class TradingSignal:
    """Trading signal generated from belief state"""
    symbol: str
    action: str  # BUY or SELL
    quantity: float
    confidence: float
    expected_return: float
    timestamp: float
    regime: RegimeType
    signal_strength: float


class SignalGenerator:
    """
    Generates trading signals from belief states using LVR-inspired signals
    and Autonomous System's decision making framework
    """
    
    def __init__(self, config: Optional[Dict] = None):
        default_config = self._default_config()
        if config:
            default_config.update(config)
        self.config = default_config
        self.min_confidence_threshold = self.config.get('min_confidence_threshold', 0.45)
        self.min_expected_return = self.config.get('min_expected_return', 0.001)
        self.max_position_size = self.config.get('max_position_size', 0.1)
        
        # HIGH WIN RATE parameters (strict for 85% target)
        self.min_uncertainty = self.config.get('min_uncertainty', 0.08)
        self.max_uncertainty = self.config.get('max_uncertainty', 0.25)  # HARD CAP
        self.buy_bias = self.config.get('buy_bias', 0.02)
        self.symbol_weights = self.config.get('symbol_weights', {'BTC/USDT': 1.0, 'ETH/USDT': 0.7})
        
    def _default_config(self) -> Dict:
        """Default signal generation configuration"""
        return {
            'min_confidence_threshold': 0.45,
            'min_expected_return': 0.001,
            'max_position_size': 0.1,
            'volatility_scaling': True,
            'regime_filters': True,
            # HIGH WIN RATE parameters (strict for 85% target)
            'min_uncertainty': 0.08,
            'max_uncertainty': 0.25,  # HARD CAP - reject >25% uncertainty
            'buy_bias': 0.02,
            'symbol_weights': {'BTC/USDT': 1.0, 'ETH/USDT': 0.7},
        }
    
    def generate_signals(self, belief_state: BeliefState, symbol: str) -> List[TradingSignal]:
        """
        Generate trading signals from belief state using multi-uncertainty model
        
        Args:
            belief_state: Current belief state
            symbol: Trading symbol
            
        Returns:
            List of trading signals (may be empty)
        """
        signals = []
        
        expected_return = belief_state.expected_return
        confidence = belief_state.confidence
        regime, regime_prob = belief_state.get_most_likely_regime()
        volatility = belief_state.volatility_estimate
        
        epistemic_uncertainty = getattr(belief_state, 'epistemic_uncertainty', 0.0)
        aleatoric_uncertainty = getattr(belief_state, 'aleatoric_uncertainty', 0.0)
        expected_return_uncertainty = getattr(belief_state, 'expected_return_uncertainty', 0.0)
        
        # Calculate total uncertainty
        total_uncertainty = (epistemic_uncertainty + aleatoric_uncertainty + expected_return_uncertainty) / 3
        
        # APEX: Enforce Apex thresholds
        min_conf = self.min_confidence_threshold
        min_ret = self.min_expected_return
        max_unc = self.max_uncertainty
        
        if confidence < min_conf:
            return signals
        if abs(expected_return) < min_ret:
            return signals
        if total_uncertainty > max_unc:
            return signals
            
        # Determine action
        if expected_return > 0:
            action = "BUY"
        elif expected_return < 0:
            action = "SELL"
        else:
            return signals
            
        # Calculate signal quality
        signal_quality = self.calculate_signal_quality(
            confidence,
            action,
            symbol,
            epistemic_uncertainty,
            aleatoric_uncertainty,
            expected_return_uncertainty
        )
        
        # Calculate base quantity
        base_quantity = min(
            self.max_position_size,
            abs(expected_return) * confidence * 10
        )
        
        # Adjust for volatility
        if self.config.get('volatility_scaling', True):
            volatility_factor = max(0.1, 1.0 - volatility)
            base_quantity *= volatility_factor
        
        # Adjust for quality and leverage
        adjusted_quantity = self.adjust_position_size(
            action,
            symbol,
            base_quantity,
            epistemic_uncertainty,
            aleatoric_uncertainty,
            expected_return_uncertainty,
            confidence
        )
        
        # Ensure minimum quantity
        if abs(adjusted_quantity) < 0.001:
            return signals
        
        # Calculate signal strength
        signal_strength = signal_quality * abs(expected_return) * 100
        
        # SIGNAL STRENGTH GATE
        min_signal_strength = self.config.get('min_signal_strength', 0.01)
        if signal_strength < min_signal_strength:
            return signals
        
        # Create signal
        signal = TradingSignal(
            symbol=symbol,
            action=action,
            quantity=adjusted_quantity,
            confidence=confidence,
             expected_return=expected_return,
             timestamp=belief_state.timestamp / 1e9,
             regime=regime,
              signal_strength=signal_strength
          )
          
          signals.append(signal)
          return signals
            
        if abs(expected_return) < self.min_expected_return:
            return signals
            
        if expected_return > self.min_expected_return:
            action = "BUY"
        elif expected_return < -self.min_expected_return:
            action = "SELL"
        else:
            return signals
            
        base_quantity = min(
            self.max_position_size,
            abs(expected_return) * confidence * 10
        )
        
        if self.config['volatility_scaling']:
            volatility_factor = max(0.1, 1.0 - volatility)
            base_quantity *= volatility_factor
            
        if self.config['regime_filters']:
            # STRICTER regime filters for 85% win rate
            if regime == RegimeType.CRISIS and confidence < 0.85:
                return signals
            if regime == RegimeType.RECOVERY and confidence < 0.65:
                return signals
            if regime == RegimeType.BEAR_HIGH_VOL and confidence < 0.70:
                return signals
        
        # APEX: Enforce Apex thresholds BEFORE signal generation
        min_conf = self.config.get('min_confidence_threshold', 0.65)
        min_ret = self.config.get('min_expected_return', 0.007)
        max_unc = self.config.get('max_uncertainty', 0.12)
        
        if confidence < min_conf or abs(expected_return) < min_ret or total_uncertainty > max_unc:
            return signals
        
        adjusted_quantity = self.adjust_position_size(
            action,
            symbol,
            base_quantity,
            epistemic_uncertainty,
            aleatoric_uncertainty,
            expected_return_uncertainty,
            confidence
        )
        
        # Ensure minimum quantity
        if abs(adjusted_quantity) < 0.001:
            return signals
        
        # Increase multiplier to ensure signal_strength passes threshold
        signal_strength = signal_quality * abs(expected_return) * 100  # Changed from 10 to 100
        
        # SIGNAL STRENGTH GATE for 85% win rate - strict threshold
        min_signal_strength = self.config.get('min_signal_strength', 0.25)
        if signal_strength < min_signal_strength:
            return signals
            if regime == RegimeType.RECOVERY and confidence < 0.65:
                return signals
            if regime == RegimeType.BEAR_HIGH_VOL and confidence < 0.70:
                return signals
        
        adjusted_quantity = self.adjust_position_size(
            action,
            symbol,
            base_quantity,
            epistemic_uncertainty,
            aleatoric_uncertainty,
            expected_return_uncertainty,
            confidence
        )
        
        signal_strength = signal_quality * abs(expected_return) * 10
        
        # SIGNAL STRENGTH GATE for 85% win rate - strict threshold
        min_signal_strength = self.config.get('min_signal_strength', 0.20)
        if signal_strength < min_signal_strength:
            return signals
        
        signal = TradingSignal(
            symbol=symbol,
            action=action,
            quantity=adjusted_quantity,
            confidence=confidence,
            expected_return=expected_return,
            timestamp=belief_state.timestamp / 1e9,
            regime=regime,
            signal_strength=signal_strength
        )
        
        signals.append(signal)
        return signals
        
    def generate_signals_batch(self, belief_states: Dict[str, BeliefState], filter_by_uncertainty: bool = True) -> List[TradingSignal]:
        """
        Generate signals for multiple symbols with optional uncertainty filtering
        
        Args:
            belief_states: Dictionary mapping symbols to belief states
            filter_by_uncertainty: Whether to apply uncertainty gates and adaptive thresholds
            
        Returns:
            List of trading signals for all symbols
        """
        signals = []
        for symbol, belief_state in belief_states.items():
            signals.extend(self.generate_signals(belief_state, symbol))
        
        if filter_by_uncertainty:
            signals = self.filter_signals_by_uncertainty(signals, belief_states)
        
        return signals
        
    def calculate_signal_quality(
        self,
        confidence,
        action,
        symbol,
        epistemic_uncertainty=None,
        aleatoric_uncertainty=None,
        expected_return_uncertainty=None
    ):
        """Calculate quality-adjusted confidence score (0-1) using multi-uncertainty model
        
        Args:
            confidence: Base confidence from belief state
            action: BUY or SELL
            symbol: Trading symbol
            epistemic_uncertainty: Model uncertainty (reducible) - higher = less reliable
            aleatoric_uncertainty: Data uncertainty (irreducible) - represents noise floor
            expected_return_uncertainty: Expected return uncertainty
            
        Returns:
            Quality-adjusted score (0-1)
        """
        epistemic_uncertainty = epistemic_uncertainty or 0.0
        aleatoric_uncertainty = aleatoric_uncertainty or 0.0
        expected_return_uncertainty = expected_return_uncertainty or 0.0
        
        score = confidence * self.symbol_weights.get(symbol, 0.5)
        
        epistemic_bonus = self._compute_epistemic_bonus(epistemic_uncertainty)
        aleatoric_penalty = self._compute_aleatoric_penalty(aleatoric_uncertainty)
        return_uncertainty_bonus = self._compute_return_uncertainty_bonus(expected_return_uncertainty)
        
        score += epistemic_bonus + aleatoric_penalty + return_uncertainty_bonus
        
        if action == "BUY":
            score += self.buy_bias
        
        return np.clip(score, 0.0, 1.0)
    
    def _compute_epistemic_bonus(self, epistemic_uncertainty: float) -> float:
        """Compute epistemic (model) uncertainty bonus
        
        Lower epistemic uncertainty = model is confident = bonus
        Higher epistemic uncertainty = model is uncertain = penalty
        
        Args:
            epistemic_uncertainty: Model uncertainty [0, 1]
            
        Returns:
            Bonus in range [-0.15, +0.15]
        """
        epistemic_uncertainty = np.clip(epistemic_uncertainty, 0.0, 1.0)
        
        if epistemic_uncertainty < 0.05:
            return 0.15
        elif epistemic_uncertainty < 0.10:
            return 0.10
        elif epistemic_uncertainty < 0.15:
            return 0.05
        elif epistemic_uncertainty < 0.25:
            return 0.0
        elif epistemic_uncertainty < 0.40:
            return -0.05
        else:
            return -0.15
    
    def _compute_aleatoric_penalty(self, aleatoric_uncertainty: float) -> float:
        """Compute aleatoric (data) uncertainty penalty
        
        Lower aleatoric uncertainty = clean data = bonus
        Higher aleatoric uncertainty = noisy data = penalty
        
        Args:
            aleatoric_uncertainty: Data uncertainty [0, 1]
            
        Returns:
            Bonus in range [-0.10, +0.10]
        """
        aleatoric_uncertainty = np.clip(aleatoric_uncertainty, 0.0, 1.0)
        
        if aleatoric_uncertainty < 0.02:
            return 0.10
        elif aleatoric_uncertainty < 0.05:
            return 0.05
        elif aleatoric_uncertainty < 0.10:
            return 0.0
        elif aleatoric_uncertainty < 0.20:
            return -0.03
        else:
            return -0.10
    
    def _compute_return_uncertainty_bonus(self, expected_return_uncertainty: float) -> float:
        """Compute expected return uncertainty bonus
        
        Lower return uncertainty = precise prediction = bonus
        Higher return uncertainty = imprecise prediction = penalty
        
        Args:
            expected_return_uncertainty: Return uncertainty [0, 1]
            
        Returns:
            Bonus in range [-0.10, +0.10]
        """
        expected_return_uncertainty = np.clip(expected_return_uncertainty, 0.0, 1.0)
        
        if expected_return_uncertainty < 0.02:
            return 0.10
        elif expected_return_uncertainty < 0.05:
            return 0.05
        elif expected_return_uncertainty < 0.10:
            return 0.0
        elif expected_return_uncertainty < 0.20:
            return -0.05
        else:
            return -0.10
    
    def should_accept_signal(
        self,
        action,
        symbol,
        epistemic_uncertainty=None,
        aleatoric_uncertainty=None,
        expected_return_uncertainty=None,
        base_confidence=None
    ):
        """Determine signal acceptance based on quality filters with multi-uncertainty model
        
        Args:
            action: BUY or SELL
            symbol: Trading symbol
            epistemic_uncertainty: Model uncertainty (optional)
            aleatoric_uncertainty: Data uncertainty (optional)
            expected_return_uncertainty: Return uncertainty (optional)
            base_confidence: Base confidence to use (optional)
            
        Returns:
            True if signal passes quality filters
        """
        quality = self.calculate_signal_quality(
            base_confidence or 0.35,
            action,
            symbol,
            epistemic_uncertainty,
            aleatoric_uncertainty,
            expected_return_uncertainty
        )
        
        return quality >= self.min_confidence_threshold
    
    def adjust_position_size(
        self,
        action,
        symbol,
        base_quantity,
        epistemic_uncertainty=None,
        aleatoric_uncertainty=None,
        expected_return_uncertainty=None,
        base_confidence=0.5
    ):
        """Adjust position size based on signal quality and leverage with multi-uncertainty model
        
        Args:
            action: BUY or SELL
            symbol: Trading symbol
            base_quantity: Original calculated position size
            epistemic_uncertainty: Model uncertainty
            aleatoric_uncertainty: Data uncertainty
            expected_return_uncertainty: Return uncertainty
            base_confidence: Base confidence score
            
        Returns:
            Adjusted position size (with leverage applied)
        """
        # Use actual confidence to calculate quality
        quality = self.calculate_signal_quality(
            base_confidence,
            action,
            symbol,
            epistemic_uncertainty,
            aleatoric_uncertainty,
            expected_return_uncertainty
        )
        
        # If quality is too low, return 0
        if quality < 0.55:
            return 0.0
        
        if quality >= 0.80:
            quality_factor = 1.0
            leverage_factor = 30.0
        elif quality >= 0.65:
            quality_factor = 0.7
            leverage_factor = 15.0
        elif quality >= 0.55:
            quality_factor = 0.3
            leverage_factor = 5.0
        else:
            quality_factor = 0.0
            leverage_factor = 0.0
            
        leveraged_quantity = base_quantity * quality_factor * leverage_factor
        
        max_leverage_position = self.max_position_size * leverage_factor
        if abs(leveraged_quantity) > max_leverage_position:
            leveraged_quantity = max_leverage_position * (1 if leveraged_quantity >= 0 else -1)
            
        return leveraged_quantity
    
    def update_config(self, config: Dict):
        """Update signal generator configuration"""
        self.config.update(config)
        self.min_confidence_threshold = self.config.get('min_confidence_threshold', 0.45)
        self.min_expected_return = self.config.get('min_expected_return', 0.001)
        self.max_position_size = self.config.get('max_position_size', 0.1)
        self.min_uncertainty = self.config.get('min_uncertainty', 0.08)
        self.max_uncertainty = self.config.get('max_uncertainty', 0.25)
        self.buy_bias = self.config.get('buy_bias', 0.02)
        self.symbol_weights = self.config.get('symbol_weights', {'BTC/USDT': 1.0, 'ETH/USDT': 0.7})
    
    def get_adaptive_threshold(
        self,
        regime: RegimeType,
        epistemic_uncertainty: float = 0.0,
        aleatoric_uncertainty: float = 0.0
    ) -> float:
        """Get adaptive confidence threshold based on regime and uncertainty
        
        Args:
            regime: Current market regime
            epistemic_uncertainty: Model uncertainty
            aleatoric_uncertainty: Data uncertainty
            
        Returns:
            Adjusted confidence threshold [0.0, 1.0]
        """
        base_threshold = self.min_confidence_threshold
        
        regime_adjustments = {
            RegimeType.BULL_LOW_VOL: -0.03,
            RegimeType.BULL_HIGH_VOL: 0.0,
            RegimeType.BEAR_LOW_VOL: 0.08,
            RegimeType.BEAR_HIGH_VOL: 0.12,
            RegimeType.SIDEWAYS_LOW_VOL: 0.0,
            RegimeType.SIDEWAYS_HIGH_VOL: 0.08,
            RegimeType.CRISIS: 0.20,
            RegimeType.RECOVERY: 0.05,
        }
        
        regime_adjustment = regime_adjustments.get(regime, 0.0)
        
        # APEX: Regime-Adaptive Confidence Tax
        # Increase threshold during high volatility or crisis to maintain 85% WR
        if regime == RegimeType.CRISIS:
            regime_adjustment += 0.15
        elif regime == RegimeType.BEAR_HIGH_VOL:
            regime_adjustment += 0.05
            
        # STRICTER uncertainty penalty for 85% win rate
        uncertainty_penalty = (
            0.10 * min(epistemic_uncertainty / 0.15, 1.0) +
            0.05 * min(aleatoric_uncertainty / 0.08, 1.0)
        )
        
        adaptive_threshold = base_threshold + regime_adjustment + uncertainty_penalty
        
        return np.clip(adaptive_threshold, 0.25, 0.60)
    
    def get_uncertainty_gate(
        self,
        epistemic_uncertainty: float,
        aleatoric_uncertainty: float,
        regime: RegimeType
    ) -> bool:
        """Check if signal passes uncertainty gate based on regime
        
        Args:
            epistemic_uncertainty: Model uncertainty
            aleatoric_uncertainty: Data uncertainty
            regime: Current market regime
            
        Returns:
            True if signal passes uncertainty gate
        """
        if regime == RegimeType.CRISIS:
            max_epistemic = 0.10
            max_aleatoric = 0.05
        elif regime == RegimeType.BEAR_HIGH_VOL:
            max_epistemic = 0.15
            max_aleatoric = 0.08
        elif regime == RegimeType.BEAR_LOW_VOL:
            max_epistemic = 0.20
            max_aleatoric = 0.10
        elif regime == RegimeType.RECOVERY:
            max_epistemic = 0.25
            max_aleatoric = 0.12
        elif regime == RegimeType.SIDEWAYS_HIGH_VOL:
            max_epistemic = 0.20
            max_aleatoric = 0.10
        else:
            max_epistemic = 0.30
            max_aleatoric = 0.15
        
        passes_epistemic = epistemic_uncertainty <= max_epistemic
        passes_aleatoric = aleatoric_uncertainty <= max_aleatoric
        
        return passes_epistemic and passes_aleatoric
    
    def filter_signals_by_uncertainty(
        self,
        signals: List[TradingSignal],
        belief_states: Dict[str, BeliefState]
    ) -> List[TradingSignal]:
        """Filter signals using uncertainty gates and adaptive thresholds
        
        Args:
            signals: List of trading signals
            belief_states: Dictionary of belief states by symbol
            
        Returns:
            Filtered list of signals
        """
        filtered = []
        
        for signal in signals:
            belief_state = belief_states.get(signal.symbol)
            if not belief_state:
                continue
            
            regime, _ = belief_state.get_most_likely_regime()
            epistemic_uncertainty = getattr(belief_state, 'epistemic_uncertainty', 0.0)
            aleatoric_uncertainty = getattr(belief_state, 'aleatoric_uncertainty', 0.0)
            
            if not self.get_uncertainty_gate(epistemic_uncertainty, aleatoric_uncertainty, regime):
                continue
            
            adaptive_threshold = self.get_adaptive_threshold(regime, epistemic_uncertainty, aleatoric_uncertainty)
            
            if signal.confidence < adaptive_threshold:
                continue
            
            filtered.append(signal)
        
        return filtered